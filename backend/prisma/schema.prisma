generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int        @id @default(autoincrement())
  email    String     @unique
  password String
  boletins Boletins[]
  membro   Membros?
}

model Membros {
  id            Int     @id @default(autoincrement())
  user_id       Int     @unique
  name          String
  profile_image String?
  role          String  @default("aluno")
  curriculum    String?
  user          User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Boletins {
  id            Int      @id @default(autoincrement())
  title         String
  category      String
  date          DateTime @default(now())
  content       String
  reference     String
  proofreader   String
  image         String?
  legend_image  String?
  created_by_id Int
  created_in    DateTime @default(now())
  writers       String
  autor         User     @relation(fields: [created_by_id], references: [id])
}

model Patrocinadores {
  id            Int     @id @default(autoincrement())
  name          String
  profile_image String?
}
