// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  membro   Membros?
  boletins Boletins[]
}

model Membros {
  id            Int       @id @default(autoincrement())
  user_id       Int       @unique
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name          String
  profile_image String?
  role          String    @default("aluno")
  curriculum    String?
}

model Boletins {
  id           Int      @id @default(autoincrement())
  title        String
  category     String
  date         DateTime @default(now())
  content      String
  reference    String
  proofreader  String
  image        String?
  legend_image String?

  created_by_id Int
  autor         User     @relation(fields: [created_by_id], references: [id])
  created_in    DateTime @default(now())
}

model Patrocinadores {
  id            Int     @id @default(autoincrement())
  name          String
  profile_image String?
}
